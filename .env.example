# Copy this file to .env and fill in your real values. Never commit .env itself.

# The token Play-Cricket issued to Barwell CC after your club admin signed
# their data-access agreement.
PLAY_CRICKET_API_TOKEN=

# Barwell CC's site_id on Play-Cricket. Find it in the URL of your own site,
# e.g. https://play-cricket.com/website/results/1234567 -> site_id is 1234567.
# (See "How to find your Play-Cricket Club ID" on the Play-Cricket help site
# if that number isn't obvious from your URLs.)
PLAY_CRICKET_SITE_ID=

# Barwell CC's club_id (used to work out which side of each fixture is us).
# Often visible in the same admin area as the site_id.
PLAY_CRICKET_CLUB_ID=
